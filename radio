<script>
  // ─── AUDIO ARCHIVE DATA ───
  const SONG_DATABASE = [
    { title: "Neon Horizon Shimmer", artist: "Arcade Frequency", src: "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3", duration: "06:12" },
    { title: "Analogue Friction Patterns", artist: "Hologram Suite", src: "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-2.mp3", duration: "07:05" },
    { title: "Static Resonance Echo", artist: "Vapor Drone Collective", src: "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-3.mp3", duration: "05:44" },
    { title: "The Noise Between Us", artist: "Signal 01", src: "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-4.mp3", duration: "05:02" },
    { title: "Sub-surface Oscillations", artist: "Tape Loop Project", src: "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-5.mp3", duration: "06:03" }
  ];

  // State Properties
  let isTapeInserted = false;
  let isPlaying = false;
  let isShuffle = false;
  let currentTrackIndex = 0;
  let currentCounter = 0;
  let counterInterval = null;
  let knobRotation = 0;

  // Audio Object Instantiation
  const audioNode = new Audio();
  audioNode.volume = 0.7;

  // DOM Elements Selector Cache
  const cursor = document.getElementById('cursor');
  const ring = document.getElementById('ring');
  const cassette = document.getElementById('cassette');
  const slot = document.getElementById('slot');
  const slotHint = document.getElementById('slot-hint');
  const slotStatic = document.getElementById('slot-static');
  const dMode = document.getElementById('dmode');
  const ticker = document.getElementById('ticker');
  const ledPlay = document.getElementById('led-play');
  const ledRec = document.getElementById('led-rec');
  const tapeCounter = document.getElementById('counter');
  const songTitle = document.getElementById('song-title');
  const songArtist = document.getElementById('song-artist');
  const progressFill = document.getElementById('progress-fill');
  const timeCurrent = document.getElementById('time-current');
  const timeTotal = document.getElementById('time-total');
  const emptyState = document.getElementById('empty-state');
  const trackContainer = document.getElementById('track-container');
  const directoryCount = document.getElementById('directory-count');
  const statusConsole = document.getElementById('status-console');
  const recIndicator = document.getElementById('rec-indicator');

  // Initialize Events on Slot
  slot.addEventListener('click', () => {
    if (!isTapeInserted) {
      insertCassette();
    }
  });

  // ─── CURSOR ENGINE ───
  document.addEventListener('mousemove', (e) => {
    cursor.style.left = e.clientX + 'px';
    cursor.style.top = e.clientY + 'px';
    ring.style.left = e.clientX + 'px';
    ring.style.top = e.clientY + 'px';
  });

  // ─── CASSETTE ACTIONS ───
  function insertCassette() {
    isTapeInserted = true;
    slotHint.innerText = "TAPE LOADED";
    cassette.classList.remove('ejected');
    slotStatic.classList.add('on');
    statusConsole.innerText = "MOUNTING CASSETTE SEGMENT... PARSING TRACK HEADERS.";

    setTimeout(() => {
      slotStatic.classList.remove('on');
      dMode.innerText = "■ STOP";
      emptyState.style.display = "none";
      trackContainer.style.display = "flex";
      directoryCount.innerText = `${SONG_DATABASE.length} TRACKS DETECTED`;
      statusConsole.innerText = "TAPE DECK ACTIVE. READY TO GENERATE AUDIO CARRIER SIGNALS.";
      
      // Select a totally random track to queue up first upon insertion
      currentTrackIndex = Math.floor(Math.random() * SONG_DATABASE.length);
      buildTracklistUI();
      loadTrack(currentTrackIndex);
      
      // Automatically trigger play right away
      togglePlay();
    }, 600);
  }

  function ejectCassette() {
    if (!isTapeInserted) return;
    stopAll();
    isTapeInserted = false;
    slotHint.innerText = "CLICK TO INSERT";
    cassette.classList.add('ejected');
    
    // Clear out UI State
    emptyState.style.display = "block";
    trackContainer.style.display = "none";
    directoryCount.innerText = "0 TRACKS AVAILABLE";
    songTitle.innerText = "NO TAPE DETECTED";
    songArtist.innerText = "INSERT MIX TAPE";
    ticker.innerText = "BETWEEN THE NOTES · RADIO · INSERT TAPE TO BEGIN · · ·";
    ticker.classList.remove('running');
    dMode.innerText = "■ STOP";
    statusConsole.innerText = "CASSETTE DISMOUNTED. ENGINE IDLE.";
  }

  // ─── CONTROLS ENGINE ───
  function loadTrack(index) {
    if (!isTapeInserted) return;
    currentTrackIndex = index;
    const currentTrack = SONG_DATABASE[currentTrackIndex];
    audioNode.src = currentTrack.src;
    
    songTitle.innerText = currentTrack.title;
    songArtist.innerText = currentTrack.artist;
    ticker.innerText = `NOW PLAYING: ${currentTrack.title.toUpperCase()} BY ${currentTrack.artist.toUpperCase()} ─── `;
    
    // Update active row visual accent
    const items = document.querySelectorAll('.track-item');
    items.forEach((item, idx) => {
      if (idx === index) item.classList.add('active');
      else item.classList.remove('active');
    });

    statusConsole.innerText = `LOADED PATH: ${currentTrack.title}. EXTRACTING COMPRESSED DATA.`;
  }

  function togglePlay() {
    if (!isTapeInserted) {
      // Prompt lazy users to add tape first
      insertCassette();
      return;
    }

    if (isPlaying) {
      audioNode.pause();
      isPlaying = false;
      dMode.innerText = "❚❚ PAUSE";
      ledPlay.className = "led off";
      recIndicator.classList.remove('on');
      document.getElementById('rl').className = "";
      document.getElementById('rr').className = "";
      clearInterval(counterInterval);
    } else {
      audioNode.play().then(() => {
        isPlaying = true;
        dMode.innerText = "▶ PLAY";
        ledPlay.className = "led grn";
        recIndicator.classList.add('on');
        ticker.classList.add('running');
        document.getElementById('rl').className = "spinning-cw";
        document.getElementById('rr').className = "spinning-cw";
        
        // Counter Incrementation Engine
        counterInterval = setInterval(() => {
          currentCounter++;
          updateCounterDisplay();
        }, 1000);
      }).catch(err => {
        statusConsole.innerText = "AUDIO TRANSMISSION ERROR. BROWSER ACCESS DENIED.";
      });
    }
  }

  function stopAll() {
    audioNode.pause();
    audioNode.currentTime = 0;
    isPlaying = false;
    dMode.innerText = "■ STOP";
    ledPlay.className = "led off";
    recIndicator.classList.remove('on');
    ticker.classList.remove('running');
    document.getElementById('rl').className = "";
    document.getElementById('rr').className = "";
    clearInterval(counterInterval);
  }

  function nextTrack() {
    if (!isTapeInserted) return;
    if (isShuffle) {
      currentTrackIndex = Math.floor(Math.random() * SONG_DATABASE.length);
    } else {
      currentTrackIndex = (currentTrackIndex + 1) % SONG_DATABASE.length;
    }
    loadTrack(currentTrackIndex);
    if (isPlaying) { audioNode.play(); } else { togglePlay(); }
  }

  function prevTrack() {
    if (!isTapeInserted) return;
    currentTrackIndex = (currentTrackIndex - 1 + SONG_DATABASE.length) % SONG_DATABASE.length;
    loadTrack(currentTrackIndex);
    if (isPlaying) { audioNode.play(); } else { togglePlay(); }
  }

  function toggleShuffle() {
    isShuffle = !isShuffle;
    const btn = document.getElementById('btn-shuf');
    if (isShuffle) {
      btn.classList.add('on');
      statusConsole.innerText = "SHUFFLE PROTOCOL ACTIVATED. RANDOM PATH SELECTION LOADED.";
    } else {
      btn.classList.remove('on');
      statusConsole.innerText = "LINEAR TRACKING SYSTEM ENGAGED.";
    }
  }

  // ─── AUDIO UTILITIES ───
  audioNode.addEventListener('timeupdate', () => {
    if (!audioNode.duration) return;
    const progress = (audioNode.currentTime / audioNode.duration) * 100;
    progressFill.style.width = `${progress}%`;
    timeCurrent.innerText = formatTime(audioNode.currentTime);
    timeTotal.innerText = formatTime(audioNode.duration);
  });

  audioNode.addEventListener('ended', () => {
    nextTrack();
  });

  function seekAudio(event) {
    if (!isTapeInserted || !audioNode.duration) return;
    const rect = event.currentTarget.getBoundingClientRect();
    const clickX = event.clientX - rect.left;
    const percentage = clickX / rect.width;
    audioNode.currentTime = percentage * audioNode.duration;
  }

  function changeVolume(val) {
    audioNode.volume = val;
  }

  function rotateKnob() {
    knobRotation = (knobRotation + 45) % 360;
    document.getElementById('kn-track').style.transform = `rotate(${knobRotation}deg)`;
    const valMapping = Math.floor(knobRotation / 45);
    document.getElementById('track-val').innerText = valMapping;
    
    // Simulate audio glitch feedback on tracking change
    if (isTapeInserted) {
      slotStatic.classList.add('on');
      setTimeout(() => slotStatic.classList.remove('on'), 150);
    }
  }

  function updateCounterDisplay() {
    let str = currentCounter.toString().padStart(4, '0');
    tapeCounter.innerText = str.split('').join(' ');
  }

  function resetCounter() {
    currentCounter = 0;
    updateCounterDisplay();
  }

  function setChannel(num) {
    const buttons = document.querySelectorAll('.ch-btn');
    buttons.forEach((b, i) => {
      if (i === num) b.classList.add('active');
      else b.classList.remove('active');
    });
    statusConsole.innerText = `MUTATING FREQUENCY CARRIER LINE TO NODE CH-${num + 1}.`;
  }

  function formatTime(secs) {
    const m = Math.floor(secs / 60).toString().padStart(2, '0');
    const s = Math.floor(secs % 60).toString().padStart(2, '0');
    return `${m}:${s}`;
  }

  function buildTracklistUI() {
    trackContainer.innerHTML = "";
    SONG_DATABASE.forEach((track, idx) => {
      const row = document.createElement('div');
      row.className = "track-item";
      row.onclick = () => { if(isTapeInserted) { loadTrack(idx); togglePlay(); } };
      row.innerHTML = `
        <div class="track-num">${(idx+1).toString().padStart(2, '0')}</div>
        <div class="track-info">
          <div class="track-fn">${track.title} ── ${track.artist}</div>
        </div>
        <div class="play-anim">
          <div class="play-bar"></div>
          <div class="play-bar"></div>
          <div class="play-bar"></div>
        </div>
        <div class="track-dur">${track.duration}</div>
      `;
      trackContainer.appendChild(row);
    });
  }

  // Realtime System Clock Implementation
  setInterval(() => {
    const d = new Date();
    document.getElementById('dh').innerText = d.getHours().toString().padStart(2, '0');
    document.getElementById('dm').innerText = d.getMinutes().toString().padStart(2, '0');
    document.getElementById('ds').innerText = d.getSeconds().toString().padStart(2, '0');
  }, 1000);

  // Scroll Reveal Intersection Observer
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(r => observer.observe(r));
</script>

</body>
</html>
